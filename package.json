  "devDependencies": {
    "@openzeppelin/contracts": "4.9.6",
    "@openzeppelin/contracts-upgradeable": "4.9.6",
    "@reclaimprotocol/solidity-sdk": "github:reclaimprotocol/reclaim-solidity-sdk#3326a4e4b7d747b3f06d027a7c40ec8612bd0b5a",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
