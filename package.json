    "pauses:verify": "tsx scripts/set-pauses.ts --verify",
    "canary:preflight": "tsx scripts/canary.ts preflight",
    "canary:status": "tsx scripts/canary.ts snapshot",
    "canary:reconcile": "tsx scripts/canary.ts reconcile",
    "proof:request": "tsx scripts/create-proof-request.ts",
    "proof:inspect": "tsx scripts/inspect-proof.ts",
    "provider:check": "tsx scripts/check-provider-hashes.ts",
    "probe:strava": "tsx scripts/probe-strava-response.ts",
