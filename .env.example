# Reclaim application credentials
# The app ID is public configuration; the secret must stay server-side.
ID=your_reclaim_app_id
SECRET=your_reclaim_secret
PROVIDER_ID=f3ec8292-d8f3-487c-a79d-f53f482f88e2
# Lock the exact audited provider version. Never silently use "latest".
PROVIDER_VERSION=1.0.1
WALLET_ADDRESS=0x...
PACT_ID=0
DAY_INDEX=0
# Optional for local testing; production generates a random challenge server-side.
# STRAVA_CHALLENGE=LI-7M4Q9X2K8P6R3T5V
# PACT_STARTS_AT=2026-07-14T13:00:00Z
MIN_DISTANCE_METERS=1000
# Strong mode is the default. Set false only to inspect old MCP fixtures without TEE.
REQUIRE_TEE_ATTESTATION=true

# Monad
MONAD_RPC_URL=https://rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC_URL=https://rpc.monad.xyz
MONAD_CHAIN_ID=143
NEXT_PUBLIC_LOCK_IN_ESCROW_ADDRESS=0x...
# Public source repository shown in the footer after publication.
# NEXT_PUBLIC_REPOSITORY_URL=https://github.com/your-account/lock-in
# Public contact required by the privacy page and production health check.
# NEXT_PUBLIC_PRIVACY_EMAIL=privacy@example.com
# Independent HMAC secret (32+ random characters) for short-lived API session tokens.
SESSION_SIGNING_SECRET=replace_with_at_least_32_random_characters

# Never expose SECRET or a deployer private key through NEXT_PUBLIC_* variables.
# DEPLOYER_PRIVATE_KEY=0x...
# Native USDC on Monad, from Circle's official address registry (6 decimals).
STAKE_TOKEN_ADDRESS=0x754704Bc059F8C67012fEd69BC8A327a5aafb603
# Official Reclaim verifier deployment configured with the current witness.
# RECLAIM_CONTRACT_ADDRESS=0x...
# Dedicated address whose server key signs only after SDK provider + TEE validation.
# EVIDENCE_SIGNER_ADDRESS=0x...
# EVIDENCE_SIGNER_PRIVATE_KEY=0x...
# Exactly 1 USDC with 6 decimals.
MAX_STAKE_ATOMIC_UNITS=1000000
