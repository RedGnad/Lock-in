# Lock In — Strava runs and ownership-bound Duolingo XP.

# Product safety gates are server-side and fail closed. Only the exact values
# `true` and `false` are valid. Start every new deployment explicitly paused.
NEW_PACTS_ENABLED=false
JOIN_ENABLED=false
CHECK_INS_ENABLED=false

# Optional comma-separated wallet allowlist for website authentication and the
# Reclaim proof API. Leave empty to accept every authenticated wallet. This is
# not an onchain allowlist and cannot block direct contract calls.
CANARY_ALLOWED_WALLETS=

# Settlement and claim intentionally have no environment flag: users must
# always retain their exit path, including during an incident.

# Monad mainnet
MONAD_RPC_URL=https://rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC_URL=https://rpc.monad.xyz
MONAD_CHAIN_ID=143
NEXT_PUBLIC_LOCK_IN_ESCROW_ADDRESS=0x...
LOCK_IN_ESCROW_CODE_HASH=0x...
LOCK_IN_STRAVA_PARSER_ADDRESS=0x...
LOCK_IN_STRAVA_VERIFIER_ADDRESS=0x...
LOCK_IN_DUOLINGO_VERIFIER_ADDRESS=0x...
LOCK_IN_STRAVA_PARSER_CODE_HASH=0x...
LOCK_IN_STRAVA_VERIFIER_CODE_HASH=0x...
LOCK_IN_DUOLINGO_VERIFIER_CODE_HASH=0x...
RECLAIM_WITNESS_ADDRESS=0x244897572368Eadf65bfBc5aec98D8e5443a9072

# Public release-authority addresses. The owner must be an already-deployed,
# tested multisig contract and must differ from the deployer and both app
# signers. The deployer address is retained for invariant checks; its private
# key remains local and never goes to Vercel.
LOCK_IN_OWNER_ADDRESS=0x...
LOCK_IN_DEPLOYER_ADDRESS=0x...

# Reclaim app credentials and the Lock In-owned providers. SESSION_SIGNING_SECRET
# also authenticates five-minute wallet challenges and 12-hour browser cookies.
# These values stay server-side; never prefix them with NEXT_PUBLIC_.
ID=
SECRET=
EVIDENCE_SIGNER_PRIVATE_KEY=0x...
ACCESS_SIGNER_PRIVATE_KEY=0x...
SESSION_SIGNING_SECRET=
DUOLINGO_PROVIDER_ID=cdf8cb3b-2976-4413-ab2d-693ae5028380

# Native USDC on Monad (6 decimals). The 1 USDC per-participation cap is
# immutable in the audited escrow bytecode and is not environment-configurable.
STAKE_TOKEN_ADDRESS=0x754704Bc059F8C67012fEd69BC8A327a5aafb603

# Public product configuration
NEXT_PUBLIC_REPOSITORY_URL=https://github.com/RedGnad/Lock-in
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@example.com

# Local deployment only. This key must resolve to LOCK_IN_DEPLOYER_ADDRESS.
# Never upload it to Vercel and never expose a private value through
# NEXT_PUBLIC_*.
# DEPLOYER_PRIVATE_KEY=0x...
# PRIVATE_KEY is also accepted by the deployment scripts.
