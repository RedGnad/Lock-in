{
  "providerId": "f3ec8292-d8f3-487c-a79d-f53f482f88e2",
  "version": "1.0.3",
  "name": "Lock In Strava authenticated GPS activity",
  "status": "published-private",
  "loginUrl": "https://www.strava.com/athlete/training",
  "description": "Proves a logged-in Strava athlete and a challenge-bound Run using canonical activity id, title, UTC start time, distance, GPS, trainer, Strava flag, and signed motion metrics.",
  "runtimePolicy": {
    "requiredSportType": "Run",
    "requiredHasLatLng": true,
    "requiredTrainer": false,
    "requiredFlagged": false,
    "maxAverageSpeedMetersPerSecond": 9,
    "minAverageSpeedMetersPerSecond": 0.5,
    "maxElapsedToMovingRatio": 4,
    "maxAdditionalPauseSeconds": 900,
    "titleMustEqualRuntimePolicy": "{{context_challenge}}",
    "dailyCodeFormat": "<pactChallenge>D01 through <pactChallenge>D30",
    "distanceField": "distance_raw",
    "timeField": "start_time",
    "providerVersionMustEqual": "1.0.3"
  },
  "requestData": [
    {
      "purpose": "Bind evidence to the currently authenticated Strava athlete",
      "url": "https://www.strava.com/athlete/training",
      "urlType": "CONSTANT",
      "method": "GET",
      "credentials": "include",
      "responseMatches": [
        { "type": "contains", "value": "\",\n   {{marker}},\n   " }
      ],
      "responseRedactions": [
        {
          "xPath": "/html[1]/head[1]/script[5]",
          "regex": "\",\\s*(?<marker>[^\"<>\\n]+),\\s*"
        }
      ]
    },
    {
      "purpose": "Extract the challenge-bound run identity, title, sport, start and integer metres",
      "url": "https://www.strava.com/athlete/training_activities?keywords={{context_challenge}}&sport_type=Run&tags=&commute=&private_activities=&trainer=false&gear=&new_activity_only=false",
      "urlType": "TEMPLATE",
      "method": "GET",
      "credentials": "include",
      "responseMatches": [
        { "type": "contains", "value": "\"id\":{{id}}" },
        { "type": "contains", "value": "\"name\":\"{{name}}\"" },
        { "type": "contains", "value": "\"sport_type\":\"{{type}}\"" },
        { "type": "contains", "value": "\"start_time\":\"{{time}}\"" },
        { "type": "contains", "value": "\"distance_raw\":{{raw}}" },
        { "type": "contains", "value": "\"flagged\":{{flagged}}" },
        { "type": "contains", "value": "\"moving_time_raw\":{{moving}}" },
        { "type": "contains", "value": "\"elapsed_time_raw\":{{elapsed}}" },
        { "type": "contains", "value": "\"elevation_gain_raw\":{{elevation}}" }
      ],
      "responseRedactions": [
        { "jsonPath": "$.models[0].id", "regex": "\"id\":(?<id>\\d+)" },
        { "jsonPath": "$.models[0].name", "regex": "\"name\":\"(?<name>[^\"<>\\n]+)\"" },
        { "jsonPath": "$.models[0].sport_type", "regex": "\"sport_type\":\"(?<type>[A-Za-z0-9_-]+)\"" },
        { "jsonPath": "$.models[0].start_time", "regex": "\"start_time\":\"(?<time>[^\"<>\\n]+)\"" },
        { "jsonPath": "$.models[0].distance_raw", "regex": "\"distance_raw\":(?<raw>\\d+)" },
        { "jsonPath": "$.models[0].flagged", "regex": "\"flagged\":(?<flagged>true|false)" },
        { "jsonPath": "$.models[0].moving_time_raw", "regex": "\"moving_time_raw\":(?<moving>\\d+)" },
        { "jsonPath": "$.models[0].elapsed_time_raw", "regex": "\"elapsed_time_raw\":(?<elapsed>\\d+)" },
        { "jsonPath": "$.models[0].elevation_gain_raw", "regex": "\"elevation_gain_raw\":(?<elevation>\\d+)" }
      ]
    },
    {
      "purpose": "Prove that Strava reports a GPS trace",
      "url": "https://www.strava.com/athlete/training_activities?keywords={{context_challenge}}&sport_type=Run&tags=&commute=&private_activities=&trainer=false&gear=&new_activity_only=false",
      "urlType": "TEMPLATE",
      "method": "GET",
      "credentials": "include",
      "responseMatches": [
        { "type": "contains", "value": "\"id\":{{id}}" },
        { "type": "contains", "value": "\"has_latlng\":{{latlng}}" }
      ],
      "responseRedactions": [
        { "jsonPath": "$.models[0].id", "regex": "\"id\":(?<id>\\d+)" },
        { "jsonPath": "$.models[0].has_latlng", "regex": "\"has_latlng\":(?<latlng>true|false)" }
      ]
    },
    {
      "purpose": "Prove that Strava does not mark the activity as trainer/indoor",
      "url": "https://www.strava.com/athlete/training_activities?keywords={{context_challenge}}&sport_type=Run&tags=&commute=&private_activities=&trainer=false&gear=&new_activity_only=false",
      "urlType": "TEMPLATE",
      "method": "GET",
      "credentials": "include",
      "responseMatches": [
        { "type": "contains", "value": "\"id\":{{id}}" },
        { "type": "contains", "value": "\"trainer\":{{trainer}}" }
      ],
      "responseRedactions": [
        { "jsonPath": "$.models[0].id", "regex": "\"id\":(?<id>\\d+)" },
        { "jsonPath": "$.models[0].trainer", "regex": "\"trainer\":(?<trainer>true|false)" }
      ]
    }
  ],
  "authoringEvidence": {
    "publishedAt": "2026-07-14",
    "authenticatedReplaySucceeded": true,
    "anonymousReplayRejected": true,
    "manualFixtureHasLatLng": false,
    "manualFixtureRejectedByRuntimePolicy": true,
    "antiCheatCoreProofVerified": true,
    "antiCheatAuthenticatedReplaySucceeded": true,
    "antiCheatAnonymousReplayRejected": true,
    "liveConfigurationReadBackViaMcp": true
  }
}
