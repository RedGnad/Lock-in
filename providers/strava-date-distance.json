{
  "providerId": "f3ec8292-d8f3-487c-a79d-f53f482f88e2",
  "version": "6.0.0",
  "name": "Lock In Strava authenticated GPS activity",
  "status": "two-claim-live-capture-verified",
  "loginUrl": "https://www.strava.com/athlete/training",
  "useIncognitoWebview": false,
  "description": "Proves a logged-in Strava athlete and a challenge-bound Run using canonical activity id, title, UTC start time, distance, GPS, trainer, Strava flag, and signed motion metrics.",
  "runtimePolicy": {
    "requiredSportType": "Run",
    "requiredHasLatLng": true,
    "requiredTrainer": false,
    "requiredFlagged": false,
    "maxAverageSpeedMetersPerSecond": 9,
    "minAverageSpeedMetersPerSecond": 0.5,
    "maxElapsedToMovingRatio": 4,
    "maxAdditionalPauseSeconds": 900,
    "titleMustEqualRuntimePolicy": "{{context_challenge}}",
    "dailyCodeFormat": "<pactChallenge>D01 through <pactChallenge>D30",
    "distanceField": "distance_raw",
    "timeField": "start_time",
    "providerVersionMustEqual": "set to the newly published two-claim version"
  },
  "requestData": [
    {
      "purpose": "Bind evidence to the currently authenticated Strava athlete",
      "url": "https://www.strava.com/athlete/training",
      "urlType": "CONSTANT",
      "method": "GET",
      "credentials": "include",
      "responseMatches": [
        {
          "type": "contains",
          "value": "\",\n   {{marker}},\n   "
        }
      ],
      "responseRedactions": [
        {
          "xPath": "/html[1]/head[1]/script[5]",
          "regex": "\",\\s*(?<marker>[^\"<>\\n]+),\\s*"
        }
      ]
    },
    {
      "purpose": "Extract the challenge-bound run identity, title, sport, start, integer metres, GPS presence and trainer flag from a single training_activities response",
      "url": "https://www.strava.com/athlete/training_activities?keywords={{context_challenge}}&sport_type=Run&tags=&commute=&private_activities=&trainer=false&gear=&new_activity_only=false",
      "urlType": "TEMPLATE",
      "method": "GET",
      "credentials": "include",
      "responseMatches": [
        {
          "type": "contains",
          "value": "\"id\":{{id}}"
        },
        {
          "type": "contains",
          "value": "\"name\":\"{{name}}\""
        },
        {
          "type": "contains",
          "value": "\"sport_type\":\"{{type}}\""
        },
        {
          "type": "contains",
          "value": "\"start_time\":\"{{time}}\""
        },
        {
          "type": "contains",
          "value": "\"distance_raw\":{{raw}}"
        },
        {
          "type": "contains",
          "value": "\"flagged\":{{flagged}}"
        },
        {
          "type": "contains",
          "value": "\"moving_time_raw\":{{moving}}"
        },
        {
          "type": "contains",
          "value": "\"elapsed_time_raw\":{{elapsed}}"
        },
        {
          "type": "contains",
          "value": "\"elevation_gain_raw\":{{elevation}}"
        },
        {
          "type": "contains",
          "value": "\"has_latlng\":{{latlng}}"
        },
        {
          "type": "contains",
          "value": "\"trainer\":{{trainer}}"
        }
      ],
      "responseRedactions": [
        {
          "jsonPath": "$.models[0].id",
          "regex": "\"id\":(?<id>\\d+)"
        },
        {
          "jsonPath": "$.models[0].name",
          "regex": "\"name\":\"(?<name>[^\"<>\\n]+)\""
        },
        {
          "jsonPath": "$.models[0].sport_type",
          "regex": "\"sport_type\":\"(?<type>[A-Za-z0-9_-]+)\""
        },
        {
          "jsonPath": "$.models[0].start_time",
          "regex": "\"start_time\":\"(?<time>[^\"<>\\n]+)\""
        },
        {
          "jsonPath": "$.models[0].distance_raw",
          "regex": "\"distance_raw\":(?<raw>\\d+)"
        },
        {
          "jsonPath": "$.models[0].flagged",
          "regex": "\"flagged\":(?<flagged>true|false)"
        },
        {
          "jsonPath": "$.models[0].moving_time_raw",
          "regex": "\"moving_time_raw\":(?<moving>\\d+)"
        },
        {
          "jsonPath": "$.models[0].elapsed_time_raw",
          "regex": "\"elapsed_time_raw\":(?<elapsed>\\d+)"
        },
        {
          "jsonPath": "$.models[0].elevation_gain_raw",
          "regex": "\"elevation_gain_raw\":(?<elevation>\\d+)"
        },
        {
          "jsonPath": "$.models[0].has_latlng",
          "regex": "\"has_latlng\":(?<latlng>true|false)"
        },
        {
          "jsonPath": "$.models[0].trainer",
          "regex": "\"trainer\":(?<trainer>true|false)"
        }
      ]
    }
  ],
  "customInjection": {
    "source": "./strava-date-distance-injection.js",
    "sha256": "791e9977d85a5e8ee9ce8634059a856a24df54b183cd09b2912fd4b496a50bd1",
    "purpose": "Diagnostic self-reporting injection: drives the training and challenge-filtered activity GET requests after sign-in (activities request sends Accept: application/json and X-Requested-With), and if it cannot release within the window it calls reclaim.reportProviderError with the exact stage, host, /athlete/training status, training_activities status and matched title so the hosted-flow failure point is visible. Reads only the daily proof code; never reads or exports cookies."
  },
  "authoringEvidence": {
    "inheritsRequestSchemaFrom": "1.0.3",
    "requestSchemaUnchanged": false,
    "requestSchemaChange": "merged the 4 training_activities claims into 1 combined claim; provider now has 2 claims (marker + activity)",
    "claimCount": 2,
    "claimCountReducedFrom": 4,
    "publishedProviderVersionOnReclaim": "6.0.0",
    "hostedFlowRootCauseConfirmed": true,
    "hostedFlowRootCause": "the 4-claim set exceeded the hosted (Popcorn) browser lifecycle: the login-indicator re-check timed out during proof generation and the session was declared BROWSER_CONNECTION_FAILED. 2 claims reach submission.",
    "hostedFlowLastStatusObserved": "PROOF_SUBMITTED (session fa8968844e, provider version 6.0.0, no -ai prerelease tag)",
    "liveAppProofCanary": true,
    "liveConfigurationReadBackViaMcp": true,
    "liveVerificationType": "WITNESS",
    "liveRequestHashes": [
      "0xdbb40a205e1a2036ccd2b371eebc19d6e01ae3a9b2cfd414d4d7abfbd9d11f67",
      "0xe3d80a409ec480b9ef026ebc96e1737a5789b0ca05e198e37d137f36eaa7705d"
    ],
    "liveRequestHashesMatchPinnedPolicy": true,
    "capturedProofPassesContentBarrier": true,
    "capturedProofPassesOnchainGrammar": true,
    "previousVersionAuthenticatedReplaySucceeded": true,
    "previousVersionAnonymousReplayRejected": true,
    "manualFetchReturnedJsonWithLatLng": true,
    "instrumentedWithDiagnosticLogs": true,
    "draftInjectionSyntaxChecked": true,
    "reuseBrowserSession": true
  }
}
